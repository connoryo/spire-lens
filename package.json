  "description": "Slay the Spire 2 run analyzer",
  "main": "out/main/main.js",
  "author": "connoryo",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "electron:build": "electron-vite build && electron-builder --publish never",
    "electron:build:win": "electron-vite build && electron-builder --win --publish never",
    "electron:build:mac": "electron-vite build && electron-builder --mac --publish never",
    "electron:build:linux": "electron-vite build && electron-builder --linux --publish never"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "lucide-react": "^0.447.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.2",
    "recharts": "^2.13.0",
    "tailwind-merge": "^2.5.3"
  },
  "devDependencies": {
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.2",
    "autoprefixer": "^10.4.20",
    "electron": "^41.2.2",
    "electron-builder": "^26.8.1",
    "electron-vite": "^3.1.0",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.13",
    "typescript": "^5.6.3",
    "vite": "^6.4.2"
  },
  "build": {
    "appId": "com.sts2viewer.app",
